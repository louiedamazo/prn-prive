generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model videos {
  id          Int     @id @default(autoincrement())
  titulo      String
  duracao     String?
  thumb_id    String?
  video_id    String?
  modelo      String?
  capa_id     String?
  modelo_slug String?
}
